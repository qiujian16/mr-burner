# ── 至少配置一个 Provider ──────────────────────────────────────────────────────

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_FAST_MODEL=MiniMax-Text-01

# Qwen / 通义千问 (DashScope)
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-max
QWEN_FAST_MODEL=qwen-turbo

# 默认 Provider（claude / minimax / qwen）
DEFAULT_PROVIDER=claude
